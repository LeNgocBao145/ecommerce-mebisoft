{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/v1/auth/{**catch-all}",
          "Methods": [ "GET", "POST" ]
        },
        "Transforms": [
          { "PathPattern": "/api/v1/auth/{**catch-all}" }
        ]
      },
      "product-get-route": { // User & Admin đều xem được
        "ClusterId": "product-cluster",
        "Match": {
          "Path": "/v1/products/{**catch-all}",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathPattern": "/api/v1/products/{**catch-all}" }
        ]
      },
      "product-admin-route": { // Chỉ Admin mới được POST/PUT/DELETE
        "ClusterId": "product-cluster",
        "AuthorizationPolicy": "AdminOnly",
        "Match": {
          "Path": "/v1/products/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE" ]
        },
        "Transforms": [
          { "PathPattern": "/api/v1/products/{**catch-all}" }
        ]
      },
      "cart-route": {
        "ClusterId": "cart-cluster",
        "AuthorizationPolicy": "UserOnly",
        "Match": {
          "Path": "/v1/cart/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v1/cart/{**catch-all}" }
        ]
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/v1/orders/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v1/orders/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5000/"
          }
        }
      },
      "product-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "cart-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003/"
          }
        }
      }
    }
  },
  "MySerilog": "ApiGateway",
  "Authentication": {
    "Key": "jnHochRCln0O+w+u6DfSlEc8GbXMymxaNVdlkjRLU5s="
  }
}